{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Eviive/renovate-config:base",
    "github>Eviive/renovate-config//kubernetes/base"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "github-digest"
      ],
      "matchDepTypes": [
        "action"
      ],
      "matchDepNames": [
        "eviive/actions"
      ],
      "pinDigests": false
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchDepTypes": [
        "HelmChart"
      ],
      "matchDepNames": [
        "postgresql",
        "redis",
        "n8n"
      ],
      "pinDigests": false
    }
  ]
}
